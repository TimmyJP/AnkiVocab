{
  "manifest_version": 3,
  "name": "Anki Vocab Tool",
  "version": "1.2",
  "description": "Anki vocabulary tool that allows to fetch all data about a single word and then adding it to Anki easily.",
  "action": {
    "default_popup": "index.html",
    "default_title": "Anki Vocab Add-on"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ankivocabtool@yuuki.com",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://jisho.org/*",
    "https://tatoeba.org/*",
    "http://127.0.0.1:8765/*"
  ]
}
